# Anthropic API key (used by agents)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === GitHub channel ===
# HMAC verification of GitHub webhook payloads (ingress)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# GitHub App credentials — used to generate installation tokens for
# bare-repo clone/fetch (agents) and PR comment posting (egress).
GITHUB_APP_ID=your-app-id-here
GITHUB_APP_INSTALLATION_ID=your-installation-id-here
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your private key here...
-----END RSA PRIVATE KEY-----"

# === Slack channel ===
# Slack app-level token (xapp-...) for Socket Mode connection (ingress)
SLACK_APP_TOKEN=xapp-your-app-token-here
# Slack bot token (xoxb-...) used by ingress (thread fetch) and egress (post / files / reactions)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Slack signing secret for HTTP-mode event verification (reserved; Socket Mode does not require this)
SLACK_SIGNING_SECRET=your-signing-secret-here

# === Workspace (bare repos + worktrees) ===
# Required. Path to the bare-repos + worktrees workspace. See docs/workspace.md.
# Suggested layout: keep alongside this project, e.g. /home/you/workspace/agent-workspace
AGENT_WORKSPACE_DIR=/home/you/workspace/agent-workspace

# === Workflow report viewer ===
# Public base URL of the ingress (which serves /static/reports/{task_id}).
# When set, agents fill ResultEvent.trace_url so Slack messages link to
# the rendered report. Unset → Slack posts summary only.
# REPORT_BASE_URL=https://agent-secretary.example.com

# === Persona A/B test (issue #2) ===
# When true, every PR event also runs the monolithic single-agent
# reviewer as a *shadow task* — its result is persisted to pr_trace
# but not sent to Slack/PR. Lets us compare A (multi-persona + CTO)
# vs B (single agent) on real PRs.
# B uses the same model class as A's CTO (Opus) so the comparison
# isolates persona structure from model capability.
# Cost overhead: ~50-60% of A's per-PR cost (B is one Opus call;
# A's per-PR cost is also dominated by its single Opus CTO call).
# PR_REVIEW_AB_MODE=false

# === Logging ===
LOG_LEVEL=INFO
